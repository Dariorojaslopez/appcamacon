generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  identification String   @unique
  email          String   @unique
  password       String
  name           String
  role           String   @default("SUPER_ADMIN")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  informes              InformeDiario[]
  registrosBitacoraObra RegistroBitacoraObra[]
}

model Project {
  id          String          @id @default(cuid())
  consecutivo Int?            // Número consecutivo de la obra (se asigna al crear)
  name        String
  description String?
  code        String          @unique
  startDate   DateTime?       // Fecha inicio obra
  endDate     DateTime?       // Fecha fin obra
  // Enlace de carpeta OneDrive (compartido) si usas Microsoft Graph. Si está vacío, se usa el .env global.
  evidenciasOnedriveShareUrl String?
  // ID o URL de carpeta Google Drive para evidencias de esta obra. Si está vacío, se usa GOOGLE_DRIVE_FOLDER_ID del .env.
  evidenciasGoogleDriveFolderId String?
  logoUrl       String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  informes           InformeDiario[]
  bitacoraEventos    BitacoraEvento[]
  bitacoraClimas     BitacoraClima[]
  registrosBitacoraObra RegistroBitacoraObra[]
  frentesObraCatalog FrenteObraCatalog[]
  contratistasCatalog ContratistaCatalog[]
  encargadosCatalog EncargadoReporteCatalog[]
  cargosCatalog     CargoCatalog[]
  proveedoresCatalog ProveedorCatalog[]
  itemsCatalog      ItemCatalog[]
  budgetChapters    BudgetChapter[]
}

/// Capítulo de presupuesto (nivel 1: rubros tipo licitación / APU).
model BudgetChapter {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  codigo      String
  nombre      String
  orden       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subchapters BudgetSubchapter[]

  @@unique([projectId, codigo])
  @@index([projectId, orden])
}

/// Subcapítulo (nivel 2) dentro de un capítulo.
model BudgetSubchapter {
  id        String   @id @default(cuid())
  chapterId String
  chapter   BudgetChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  nombre    String
  orden     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ItemCatalog[]

  @@index([chapterId, orden])
}

// Frentes de obra por proyecto. Configurables en administración; el informe referencia el ítem del catálogo.
model FrenteObraCatalog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nombre    String
  orden     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  informes  InformeDiario[]

  @@unique([projectId, nombre])
  @@index([projectId, isActive, orden])
}

// Turnos / jornadas (rango horario). Configurables en administración.
model JornadaCatalog {
  id          String   @id @default(cuid())
  nombre      String
  horaInicio  String   // "HH:mm"
  horaFin     String   // "HH:mm"
  orden       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  informes    InformeDiario[]

  @@index([isActive, orden])
}

/// Tipos de condición climática / ambiente (combo en suspensiones y cabecera informe). Configurables en administración.
model TipoCondicionCatalog {
  id        String   @id @default(cuid())
  codigo    String   @unique // Valor guardado en InformeDiario.tipoClima / InformeSuspension.tipoClima
  nombre    String
  orden     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, orden])
}

model InformeDiario {
  id                 String    @id @default(cuid())
  date               DateTime
  jornadaCatalogoId  String?
  jornadaCatalogo    JornadaCatalog? @relation(fields: [jornadaCatalogoId], references: [id])
  condiciones        String?
  actividades        String?
  incidentes         String?
  evidenciasUrl      String?

  // Evidencias y cierre
  registroFotografico        Boolean? @default(false)
  observacionesGenerales     String?
  observaciones               String?
  // Cierre: las 4 firmas de evidencias completas bloquean edición del informe.
  informeCerrado             Boolean   @default(false)
  cerradoEn                  DateTime?

  // Datos generales
  informeConsecutivo Int?
  informeNo          String?
  centroTrabajoConsecutivo Int?
  centroTrabajo      String?
  frenteObra         String?
  frenteObraCatalogoId String?
  frenteObraCatalogo   FrenteObraCatalog? @relation(fields: [frenteObraCatalogoId], references: [id], onDelete: SetNull)
  contratista        String?
  contratistaCatalogoId String?
  contratistaCatalog    ContratistaCatalog? @relation(fields: [contratistaCatalogoId], references: [id], onDelete: SetNull)
  encargadoReporte   String?
  encargadoReporteCatalogoId String?
  encargadoReporteCatalog    EncargadoReporteCatalog? @relation(fields: [encargadoReporteCatalogoId], references: [id], onDelete: SetNull)
  cargo              String?   // Texto mostrado / libre; si hay catálogo, refleja su nombre
  cargoCatalogoId  String?
  cargoCatalog       CargoCatalog? @relation(fields: [cargoCatalogoId], references: [id], onDelete: SetNull)
  horaEntrada        String?   // "HH:mm"
  horaSalida         String?   // "HH:mm"

  // Jornada y condiciones
  huboSuspension     Boolean?  @default(false)
  motivoSuspension   String?
  horaSuspension     String?   // "HH:mm"
  horaReinicio       String?   // "HH:mm"
  tipoClima          String?
  horasClima         Float?
  /// Condición por franja del día (antes de suspensiones): códigos de TipoCondicionCatalog
  franjaClimaMananaCodigo String?
  franjaClimaTardeCodigo   String?
  franjaClimaNocheCodigo   String?

  // Relaciones
  userId             String
  user               User      @relation(fields: [userId], references: [id])

  projectId          String
  project            Project   @relation(fields: [projectId], references: [id])

  personal           PersonalObra[]
  equipos            EquipoObra[]
  materialIngresos  MaterialIngreso[]
  materialEntregas  MaterialEntrega[]
  actividadesObra  ActividadObra[]
  ensayosObra       EnsayoObra[]
  danosRedesObra    DanoRedesObra[]
  noConformidadesObra NoConformidadObra[]
  firmas              FirmaInforme[]
  suspensiones        InformeSuspension[]
  bitacoraEventos     BitacoraEvento[]
  bitacoraClimas      BitacoraClima[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  /// Un informe por combinación obra + día (UTC) + jornada
  @@unique([projectId, date, jornadaCatalogoId])
  @@index([projectId, date, jornadaCatalogoId])
}

/// Varias suspensiones por informe (obra + fecha + jornada).
model InformeSuspension {
  id                 String        @id @default(cuid())
  informeDiarioId    String
  informeDiario      InformeDiario @relation(fields: [informeDiarioId], references: [id], onDelete: Cascade)
  motivoSuspension   String
  horaSuspension     String
  horaReinicio       String
  tipoClima          String?
  horasClima         Float?
  imagenUrl          String?
  imagenLatitud      Float?
  imagenLongitud     Float?
  imagenPrecision    Float?
  imagenGeoEstado    String?
  imagenTomadaEn     DateTime?
  orden              Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([informeDiarioId, orden])
}

// Firmas de evidencias: una fila por tipo de rol (slot), columnas visibles en BD.
model FirmaInforme {
  id          String    @id @default(cuid())
  slot        String
  firmado     Boolean   @default(false)
  codigo      String    @default("")
  observacion String    @default("")
  firmadoEn   DateTime?

  informeId   String
  informe     InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([informeId, slot])
  @@index([informeId])
}

model PersonalObra {
  id             String   @id @default(cuid())
  nombre         String
  cargo          String
  subcontratista String?
  horaEntrada    String?  // "HH:mm"
  horaSalida     String?  // "HH:mm"

  informeId      String
  informe        InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EquipoObra {
  id            String   @id @default(cuid())
  descripcion   String
  placaRef      String?
  propiedad     String?  // PROPIO / ALQUILADO
  estado        String?  // Selección libre (ej. Operativo / Fuera de servicio)
  observacion   String?
  imagenUrl     String?
  imagenLatitud Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?
  horasTrabajadas Float?
  horaIngreso   String?  // "HH:mm"
  horaSalida    String?  // "HH:mm"
  horarios      EquipoObraHorario[]

  informeId     String
  informe       InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EquipoObraHorario {
  id              String   @id @default(cuid())
  equipoId        String
  equipo          EquipoObra @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  horaIngreso     String
  horaSalida      String
  horasTrabajadas Float
  orden           Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([equipoId, orden])
}

model MaterialIngreso {
  id            String   @id @default(cuid())
  proveedor     String
  tipoMaterial  String
  noRemision    String
  unidad        String
  cantidad      Float?
  observacion   String?
  imagenUrl     String?
  imagenLatitud Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?

  informeId     String
  informe       InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MaterialEntrega {
  id            String   @id @default(cuid())
  tipoMaterial  String
  unidad        String
  cantidad      Float?
  contratista   String
  firmaRecibido Boolean  @default(false)
  observacion   String?
  imagenUrl     String?
  imagenLatitud Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?

  informeId     String
  informe       InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ActividadObra {
  id               String   @id @default(cuid())
  pk               String
  abscisadoInicial String?
  abscisadoFinal   String?
  itemContractual  String
  descripcion      String
  unidadMedida     String
  observacion      Boolean  @default(false)
  observacionTexto String?
  imagenUrl        String?
  imagenLatitud    Float?
  imagenLongitud   Float?
  imagenPrecision  Float?
  imagenGeoEstado  String?
  imagenTomadaEn   DateTime?
  largo            Float?
  ancho            Float?
  altura           Float?
  cantidadTotal    Float?   // m3

  informeId        String
  informe          InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model EnsayoObra {
  id              String   @id @default(cuid())
  materialActividad String
  tipoEnsayo     String
  idMuestra      String
  descripcion    String?

  laboratorio     String
  localizacion   String
  resultado       String
  observacion    String?
  imagenUrl      String?
  imagenLatitud  Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?

  informeId       String
  informe         InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DanoRedesObra {
  id            String   @id @default(cuid())

  horaReporte   String?
  direccion     String
  tipoDano      String
  entidad       String
  noReporte     String

  observacion   String?
  imagenUrl     String?
  imagenLatitud Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?

  informeId      String
  informe        InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NoConformidadObra {
  id String @id @default(cuid())

  noConformidad String
  detalle        String
  origen         String?
  estado         String
  imagenUrl      String?
  imagenLatitud  Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?

  informeId       String
  informe         InformeDiario @relation(fields: [informeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BitacoraEvento {
  id                  String    @id @default(cuid())
  tipoEvento          String    @map("tipo_evento")
  moduloOrigen        String    @map("modulo_origen")
  descripcion         String
  usuarioId           String?   @map("usuario_id")
  usuario             String?
  rolUsuario          String?   @map("rol_usuario")
  fecha               DateTime
  hora                String
  timestampUtc        DateTime  @default(now()) @map("timestamp_utc")
  latitud             Float?
  longitud            Float?
  precisionGps        Float?    @map("precision_gps")
  direccionAproximada String?   @map("direccion_aproximada")
  dispositivo         String?
  navegador           String?
  ip                  String?
  projectId           String    @map("proyecto_id")
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  informeId           String?   @map("informe_id")
  informe             InformeDiario? @relation(fields: [informeId], references: [id], onDelete: SetNull)
  frenteObraId        String?   @map("frente_obra_id")
  contratistaId       String?   @map("contratista_id")
  evidenciaFotografica String?  @map("evidencia_fotografica")
  firmaAsociada       String?   @map("firma_asociada")
  observaciones       String?
  estado              String    @default("ACTIVO")
  hashIntegridad      String    @map("hash_integridad")
  sourceModel         String?   @map("source_model")
  sourceId            String?   @map("source_id")
  payload             Json?
  inconsistencias     Json?
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  evidencias          BitacoraEvidencia[]
  firmas              BitacoraFirma[]
  auditorias          BitacoraAuditoria[]

  @@index([projectId, fecha, timestampUtc])
  @@index([informeId, moduloOrigen])
  @@index([sourceModel, sourceId])
  @@map("bitacora_eventos")
}

model BitacoraEvidencia {
  id          String   @id @default(cuid())
  eventoId    String   @map("evento_id")
  evento      BitacoraEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  url         String
  previewUrl  String?  @map("preview_url")
  fase        String?
  latitud     Float?
  longitud    Float?
  precisionGps Float?  @map("precision_gps")
  geoEstado   String?  @map("geo_estado")
  tomadaEn    DateTime? @map("tomada_en")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([eventoId])
  @@map("bitacora_evidencias")
}

model BitacoraFirma {
  id          String   @id @default(cuid())
  eventoId    String   @map("evento_id")
  evento      BitacoraEvento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  slot        String
  firmante    String?
  rolFirmante String?  @map("rol_firmante")
  firmadoEn   DateTime? @map("firmado_en")
  hashFirma   String?  @map("hash_firma")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([eventoId])
  @@map("bitacora_firmas")
}

model BitacoraAuditoria {
  id          String   @id @default(cuid())
  eventoId    String?  @map("evento_id")
  evento      BitacoraEvento? @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  accion      String
  tabla       String
  registroId  String?  @map("registro_id")
  valorAnterior Json?  @map("valor_anterior")
  valorNuevo    Json?  @map("valor_nuevo")
  usuarioId   String?  @map("usuario_id")
  usuario     String?
  rolUsuario  String?  @map("rol_usuario")
  ip          String?
  latitud     Float?
  longitud    Float?
  timestampUtc DateTime @default(now()) @map("timestamp_utc")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tabla, registroId])
  @@index([timestampUtc])
  @@map("bitacora_auditoria")
}

model BitacoraClima {
  id          String   @id @default(cuid())
  projectId   String   @map("proyecto_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  informeId   String?  @map("informe_id")
  informe     InformeDiario? @relation(fields: [informeId], references: [id], onDelete: SetNull)
  fecha       DateTime
  tipo        String
  temperatura Float?
  humedad     Float?
  observaciones String?
  latitud     Float?
  longitud    Float?
  precisionGps Float? @map("precision_gps")
  capturadoEn DateTime @default(now()) @map("capturado_en")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([informeId])
  @@index([projectId, fecha])
  @@map("bitacora_clima")
}

/// Registro manual de bitácora por obra (contratista, interventoría, IDU): observaciones, foto y firma cada uno.
/// Un registro por obra y día civil (`fecha`); `consecutivo` es el número de registro dentro de la obra.
model RegistroBitacoraObra {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  fecha       DateTime @db.Date
  consecutivo Int

  franjaClimaMananaCodigo String?
  franjaClimaTardeCodigo   String?
  franjaClimaNocheCodigo   String?

  contratistaObservaciones String  @default("")
  contratistaFotoUrl       String?
  contratistaFirmaUrl     String?

  interventoriaObservaciones String  @default("")
  interventoriaFotoUrl       String?
  interventoriaFirmaUrl      String?

  iduObservaciones String  @default("")
  iduFotoUrl       String?
  iduFirmaUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, fecha])
  @@index([projectId, fecha])
  @@map("registro_bitacora_obra")
}

model ContratistaCatalog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  cedula    String
  nombre    String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  informes  InformeDiario[]

  @@unique([projectId, cedula])
  @@index([projectId, isActive, nombre])
}

model EncargadoReporteCatalog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  cedula    String
  nombre    String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  informes  InformeDiario[]

  @@unique([projectId, cedula])
  @@index([projectId, isActive, nombre])
}

model CargoCatalog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Consecutivo autonumérico por obra (1, 2, 3… dentro de cada projectId)
  consecutivo Int?
  nombre    String
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  informes  InformeDiario[]

  @@unique([projectId, nombre])
  @@index([projectId, consecutivo])
  @@index([projectId, isActive, nombre])
}

model ProveedorCatalog {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tipoPersona       String
  nombreRazonSocial String
  nombreComercial   String?
  nitDocumento      String
  dv                String?
  email             String?
  telefono          String?
  celular           String?
  direccion         String?
  pais              String?
  departamento      String?
  ciudad            String?
  codigoPostal      String?
  isActive          Boolean  @default(true)

  items             ItemCatalog[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([projectId, nitDocumento])
  @@index([projectId, isActive, nombreRazonSocial])
}

model ItemCatalog {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  subchapterId  String
  subchapter    BudgetSubchapter @relation(fields: [subchapterId], references: [id], onDelete: Cascade)

  proveedorId   String?
  proveedor     ProveedorCatalog? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)

  codigo        String
  descripcion   String
  unidad        String?
  precioUnitario Float?
  cantidad      Float?
  largo         Float?
  ancho         Float?
  altura        Float?
  imagenUrl     String?
  imagenLatitud Float?
  imagenLongitud Float?
  imagenPrecision Float?
  imagenGeoEstado String?
  imagenTomadaEn DateTime?
  orden         Int      @default(0)
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([projectId, codigo])
  @@index([projectId, isActive, orden, codigo])
  @@index([proveedorId])
  @@index([subchapterId, orden])
}

model RoleMenuPermission {
  role    String
  menuKey String

  @@id([role, menuKey])
}

// Permisos de firma en Evidencias: permKey "token" = ver código en barra; resto = filas donde puede firmar.
model RoleFirmaPermission {
  role    String
  permKey String

  @@id([role, permKey])
}

model RoleLabel {
  role  String @id
  label String
}
