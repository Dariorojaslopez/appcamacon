# Plantilla — copie este archivo como ".env" en la raíz del proyecto y ajuste valores.
# El archivo real ".env" no se versiona (está en .gitignore).

# Base de datos
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/NOMBRE_BD?schema=public"

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=10h
JWT_REFRESH_EXPIRES_IN=7d

# OneDrive (opcional)
ONEDRIVE_ENABLED=false
ONEDRIVE_TENANT_ID=
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
# Carpeta por defecto para evidencias (si una obra no tiene URL propia en la BD)
ONEDRIVE_FOLDER_SHARE_URL=

# Dictado por voz: en `next dev` las IPs privadas (ej. 192.168.x.x) ya no bloquean en la app; en el celular use en su lugar:
#   npm run dev:https  →  https://192.168.x.x:3000 (aviso de certificado autofirmado = normal)
# Opcional, orígenes extra: NEXT_PUBLIC_VOICE_INSECURE_DEV_ORIGINS=http://...

# Google Drive (alternativa temporal)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
# Carpeta por defecto (opcional si cada obra tiene su ID en la BD).
GOOGLE_DRIVE_FOLDER_ID=
